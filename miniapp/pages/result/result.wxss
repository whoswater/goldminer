/* ========== 加载状态 ========== */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #eee;
  border-top-color: #c0392b;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.progress-steps {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.step {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.step-done {
  background: #c0392b;
  color: #fff;
}

.step-arrow {
  margin: 0 12rpx;
  color: #ccc;
}

/* ========== 股票头部 Hero ========== */
.stock-hero {
  background: linear-gradient(160deg, #1a1a2e, #16213e);
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-left {
  flex: 1;
}

.stock-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.hero-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.code-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.industry-tag {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.hero-right {
  text-align: right;
}

.price-main {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}

.price-change {
  font-size: 26rpx;
}

.text-rise, .price-main.text-rise, .price-change.text-rise { color: #ff6b6b; }
.text-fall, .price-main.text-fall, .price-change.text-fall { color: #51cf66; }
.text-flat { color: rgba(255,255,255,0.6); }

.metrics-row {
  display: flex;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  gap: 8rpx;
}

.metric-chip {
  flex: 1;
  text-align: center;
}

.metric-val {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.metric-lbl {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 4rpx;
}

/* ========== 行情概览 / 走势概览 网格 ========== */
.quote-grid, .trend-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.quote-item, .trend-item {
  text-align: center;
  padding: 12rpx 0;
}

.quote-val, .trend-val {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.quote-lbl, .trend-lbl {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 走势页颜色覆盖 */
.trend-val.text-rise { color: #c0392b; }
.trend-val.text-fall { color: #27ae60; }

/* ========== AI 卡片 ========== */
.ai-card {
  border-left: 6rpx solid #c0392b;
}

.ai-note {
  font-size: 22rpx;
  color: #bbb;
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.verdict-box {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.verdict-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-red { background: #fde8e8; color: #c0392b; }
.tag-green { background: #e8f8e8; color: #27ae60; }
.tag-blue { background: #e8f0fd; color: #2980b9; }
.tag-orange { background: #fef3e8; color: #e67e22; }
.tag-gray { background: #f0f0f0; color: #666; }

.ai-summary {
  background: #fef9f0;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 24rpx;
}

.ai-section {
  margin-bottom: 24rpx;
}

.ai-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.ai-section-content {
  font-size: 26rpx;
  line-height: 1.7;
  color: #555;
}

.factor-list, .risk-list {
  padding-left: 10rpx;
}

.factor-item, .risk-item {
  position: relative;
  padding-left: 24rpx;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #555;
}

.factor-item::before {
  content: '·';
  position: absolute;
  left: 0;
  color: #27ae60;
  font-weight: 700;
}

.risk-item::before {
  content: '·';
  position: absolute;
  left: 0;
  color: #e74c3c;
  font-weight: 700;
}

/* ========== 财务 / 快报 列表 ========== */
.fin-list {
  padding: 0;
}

.fin-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.fin-row:last-child {
  border-bottom: none;
}

.fin-label {
  font-size: 26rpx;
  color: #666;
}

.fin-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.fin-value.text-rise { color: #c0392b; }
.fin-value.text-fall { color: #27ae60; }

/* ========== 业绩预告 ========== */
.earnings-box {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.earnings-box:last-child {
  border-bottom: none;
}

.earnings-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.earnings-period {
  font-size: 24rpx;
  color: #999;
}

.earnings-desc {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.earnings-detail {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.earnings-reason {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* ========== 分析师预测表格 ========== */
.analyst-list {
  overflow: hidden;
}

.analyst-header, .analyst-row {
  display: flex;
}

.analyst-header {
  background: #f8f8f8;
  font-weight: 600;
  font-size: 24rpx;
  color: #666;
}

.analyst-row {
  border-bottom: 1rpx solid #f5f5f5;
}

.analyst-cell {
  flex: 1;
  padding: 14rpx 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.analyst-count {
  color: #2980b9;
}

.analyst-mean {
  font-weight: 600;
  color: #1a1a2e;
}

.analyst-range {
  color: #999;
  font-size: 24rpx;
}

/* ========== 资金流向 ========== */
.fund-summary {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.fund-total-label {
  font-size: 26rpx;
  color: #666;
}

.fund-total-val {
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 8rpx;
}

.fund-total-val.text-rise { color: #c0392b; }
.fund-total-val.text-fall { color: #27ae60; }

.fund-table {
  overflow: hidden;
}

.fund-header, .fund-row {
  display: flex;
}

.fund-header {
  background: #f8f8f8;
  font-size: 22rpx;
  font-weight: 600;
  color: #999;
}

.fund-cell {
  flex: 1;
  padding: 12rpx 8rpx;
  font-size: 24rpx;
  text-align: center;
}

.fund-cell.text-rise { color: #c0392b; }
.fund-cell.text-fall { color: #27ae60; }

/* ========== 十大股东 ========== */
.holder-list {
  padding: 0;
}

.holder-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.holder-row:last-child {
  border-bottom: none;
}

.holder-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.holder-info {
  flex: 1;
}

.holder-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.holder-detail {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* ========== 新闻 / 公告 ========== */
.news-list {
  padding: 0;
}

.news-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.news-item:last-child {
  border-bottom: none;
}

.news-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.news-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.news-source {
  font-size: 22rpx;
  color: #2980b9;
}

.news-time {
  display: block;
  font-size: 22rpx;
  color: #bbb;
}

/* ========== 通用 ========== */
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.card-sub {
  font-size: 22rpx;
  font-weight: 400;
  color: #bbb;
  margin-left: 12rpx;
}

.error-text {
  display: block;
  color: #e74c3c;
  margin-bottom: 30rpx;
}

.retry-btn {
  display: inline-block;
  background: #c0392b;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 60rpx;
  font-size: 28rpx;
}

.disclaimer {
  text-align: center;
  padding: 30rpx 20rpx 40rpx;
  font-size: 22rpx;
  color: #ccc;
  line-height: 1.6;
}
