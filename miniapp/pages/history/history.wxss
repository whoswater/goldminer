/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.clear-btn {
  font-size: 26rpx;
  color: #c0392b;
  padding: 8rpx 24rpx;
}

/* 历史列表 */
.history-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: #f8f8f8;
}

.item-left {
  flex: 1;
}

.item-code {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-right: 16rpx;
}

.item-name {
  font-size: 26rpx;
  color: #666;
}

.item-right {
  text-align: right;
}

.item-price {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.item-time {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-icon-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.empty-icon-img {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.3;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #ccc;
}
