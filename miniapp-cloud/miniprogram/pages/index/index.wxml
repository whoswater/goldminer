<!-- 首页 -->
<view class="page">
  <view class="hero">
    <text class="title">精准析查</text>
    <text class="subtitle">上市公司公开信息聚合 · AI智能分析</text>

    <view class="search-wrap">
      <view class="search-bar {{inputFocus ? 'focus' : ''}}" bindtap="focusInput">
        <view class="s-icon-wrap">
          <image class="s-icon" src="/images/search-active.png" mode="aspectFit" />
        </view>
        <input
          class="s-input"
          placeholder="搜索股票代码或名称"
          placeholder-class="s-placeholder"
          value="{{keyword}}"
          bindinput="onInput"
          bindfocus="onFocus"
          bindblur="onBlur"
          bindconfirm="onSearch"
          confirm-type="search"
          focus="{{inputFocus}}"
        />
        <view class="s-clear" wx:if="{{keyword}}" catchtap="onClear">
          <text class="s-clear-x">x</text>
        </view>
        <view class="s-go" wx:if="{{keyword}}" bindtap="onSearch">
          <text class="s-go-text">分析</text>
        </view>
      </view>

      <!-- 搜索建议 -->
      <view class="suggest" wx:if="{{suggestions.length > 0}}">
        <view class="suggest-item" wx:for="{{suggestions}}" wx:key="code" bindtap="onSelectStock" data-code="{{item.code}}" data-name="{{item.name}}">
          <text class="suggest-code">{{item.code}}</text>
          <text class="suggest-name">{{item.name}}</text>
          <text class="suggest-arrow">></text>
        </view>
      </view>
    </view>

    <view class="tags" wx:if="{{!keyword && suggestions.length === 0}}">
      <view class="tag" wx:for="{{hotStocks}}" wx:key="code" bindtap="onSelectStock" data-code="{{item.code}}" data-name="{{item.name}}">{{item.name}}</view>
    </view>
  </view>

  <view class="bottom-bar">
    <text class="bottom-text">AI摘要 · 财务数据 · 资金流向 · 股东 · 新闻</text>
    <text class="disclaimer">仅供参考，不构成投资建议</text>
  </view>

  <view class="mask" wx:if="{{suggestions.length > 0}}" bindtap="dismissSuggest"></view>
</view>
